# ── MTSecurity v2 — Environment Variables ──────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# App
APP_NAME=MTSecurity
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (SQLite for single host, switch to PostgreSQL when > 1M events)
DATABASE_URL=postgresql+asyncpg://mtsecurity:mtsec_pg_2026@localhost:5434/mtsecurity
# DATABASE_URL=sqlite+aiosqlite:///./data/mtsecurity.db

# Security — REQUIRED ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=2a9c55cbc9e98fc9ccf5f1a8fbd54f5ef3eff7003586087229e813a32303305e

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=dIPdeAiTHlLS-mC0bXeeF480pxFTipdJLamx2YSEbXg=

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI
MODEL_PATH=./data/models/yolo11n.xml
MODEL_DEVICE=CPU
AI_CONFIDENCE_THRESHOLD=0.6

# Notifications (optional — leave blank to disable)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# NLQ — Natural Language Query (optional)
ANTHROPIC_API_KEY=
NLQ_ENABLED=false
NLQ_MAX_RESULTS=50
NLQ_RATE_LIMIT_PER_MINUTE=20

# URLs ───────────────────────────────────────────────────────────────────────
# Public-facing base URL — used for building snapshot/clip links in alert messages.
# No trailing slash. In production set this to your nginx domain or IP.
BASE_URL=http://localhost:8000
# Comma-separated CORS origins. In debug mode, localhost:5173/4173 are added automatically.
CORS_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=200/minute

# Storage
SNAPSHOT_DIR=./data/snapshots
CLIP_DIR=./data/clips
MAX_SNAPSHOT_AGE_DAYS=30
DISK_ALERT_THRESHOLD_GB=20.0

# FFmpeg — path to ffmpeg executable.
# Leave empty to auto-detect from PATH.
# On Windows with a local install, set the full path, e.g.:
#   FFMPEG_PATH=D:\libs\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=D:\libs\ffmpeg\bin\ffmpeg.exe

# Clip output resolution (width x height).
# 854x480 = 16:9 landscape 480p (YouTube-friendly).
# Set both to 0 to keep original camera resolution.
CLIP_WIDTH=854
CLIP_HEIGHT=480

# Annotation — bounding box labels on snapshots
# 0.0 = auto-scale by image resolution (recommended)
# e.g. 0.6 = fixed size regardless of resolution
ANNOTATION_FONT_SCALE=0.0
# 0 = auto thickness, e.g. 2 = fixed 2px border
ANNOTATION_BOX_THICKNESS=0
